<%- include('partials/header') %>

<style>
  .page-banner { background: linear-gradient(135deg, #2ECC71, #27AE60); color: white; padding: 48px 0; text-align: center; }
  .page-banner h1 { font-size: 2rem; margin-bottom: 8px; }
  .board-container { max-width: 960px; margin: 0 auto; padding: 32px 20px; }
  .community-nav { display: flex; justify-content: center; gap: 8px; padding: 16px 0; background: #F8F9FA; border-bottom: 1px solid #eee; }
  .community-nav a { padding: 8px 20px; border-radius: 20px; text-decoration: none; color: #666; font-weight: 500; }
  .community-nav a.active { background: #2ECC71; color: white; }
  .community-nav a:hover { background: #E8FDE8; color: #27AE60; }

  .share-card { background: white; border-radius: 12px; padding: 24px; margin-bottom: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
  .share-card h3 a { color: #333; text-decoration: none; }
  .share-card h3 a:hover { color: #27AE60; }
  .share-card .meta { color: #999; font-size: 0.85rem; margin: 8px 0; }
  .share-card .lotto-balls { display: flex; gap: 6px; margin: 12px 0; }
  .mini-ball { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 700; color: white; }
  .share-card .preview { color: #666; font-size: 0.95rem; }
  .share-stats { display: flex; gap: 16px; margin-top: 12px; font-size: 0.85rem; color: #999; }

  .btn-write { padding: 10px 20px; background: #2ECC71; color: white; border: none; border-radius: 6px; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; }

  .pagination { display: flex; justify-content: center; gap: 4px; margin-top: 32px; }
  .pagination a, .pagination span { padding: 8px 14px; border: 1px solid #ddd; border-radius: 6px; color: #333; text-decoration: none; }
  .pagination .active { background: #2ECC71; color: white; border-color: #2ECC71; }
</style>

<div class="page-banner">
  <div class="container">
    <h1><i class="fas fa-share-alt"></i> 번호 공유</h1>
    <p>회원들이 추천하는 이번 주 번호를 확인하세요</p>
  </div>
</div>

<nav class="community-nav">
  <a href="/board/free">자유게시판</a>
  <a href="/board/review">당첨후기</a>
  <a href="/board/share" class="active">번호공유</a>
  <a href="/live">라이브 방송</a>
</nav>

<div class="board-container">
  <% if (isLoggedIn) { %>
    <div style="text-align: right; margin-bottom: 20px;">
      <a href="/board/share/write" class="btn-write"><i class="fas fa-pen"></i> 번호 공유하기</a>
    </div>
  <% } %>

  <% if (posts && posts.length > 0) { %>
    <% posts.forEach(post => { %>
      <div class="share-card">
        <h3><a href="/board/share/<%= post.id %>"><%= post.title %></a></h3>
        <div class="meta"><%= post.nickname %> · Lv.<%= post.level %></div>
        <% if (post.lotto_numbers) { try { const nums = JSON.parse(post.lotto_numbers); %>
          <div class="lotto-balls">
            <% nums.forEach(n => { %>
              <% let cls = n <= 10 ? 'ball-yellow' : n <= 20 ? 'ball-blue' : n <= 30 ? 'ball-red' : n <= 40 ? 'ball-gray' : 'ball-green'; %>
              <div class="mini-ball <%= cls %>"><%= n %></div>
            <% }); %>
          </div>
        <% } catch(e) {} } %>
        <p class="preview"><%= post.content.substring(0, 80) %></p>
        <div class="share-stats">
          <span><i class="fas fa-eye"></i> <%= post.view_count %></span>
          <span><i class="fas fa-heart"></i> <%= post.like_count %></span>
          <span><i class="fas fa-comment"></i> <%= post.comment_count %></span>
        </div>
      </div>
    <% }); %>
  <% } else { %>
    <div style="text-align:center; padding:60px; color:#999;">번호 공유 게시글이 없습니다.</div>
  <% } %>

  <% if (totalPages > 1) { %>
    <div class="pagination">
      <% for (let i = 1; i <= totalPages; i++) { %>
        <% if (i === page) { %><span class="active"><%= i %></span><% } else { %>
        <a href="/board/share?page=<%= i %>"><%= i %></a><% } %>
      <% } %>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
