<%- include('partials/header') %>

<style>
  .page-banner { background: linear-gradient(135deg, #1B4F72, #2C3E50); color: white; padding: 48px 0; text-align: center; }
  .page-banner h1 { font-size: 2rem; margin-bottom: 8px; }
  .lotto-container { max-width: 960px; margin: 0 auto; padding: 32px 20px; }

  .latest-draw { background: white; border-radius: 16px; padding: 32px; box-shadow: 0 4px 16px rgba(0,0,0,0.08); text-align: center; margin-bottom: 32px; }
  .latest-draw h2 { color: #1B4F72; margin-bottom: 8px; }
  .latest-draw .draw-info { color: #888; margin-bottom: 20px; }
  .lotto-display { display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; align-items: center; }
  .lotto-ball { width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; font-weight: 700; color: white; box-shadow: 0 3px 8px rgba(0,0,0,0.2); }
  .ball-yellow { background: linear-gradient(135deg, #F1C40F, #F39C12); }
  .ball-blue { background: linear-gradient(135deg, #3498DB, #2980B9); }
  .ball-red { background: linear-gradient(135deg, #E74C3C, #C0392B); }
  .ball-gray { background: linear-gradient(135deg, #95A5A6, #7F8C8D); }
  .ball-green { background: linear-gradient(135deg, #2ECC71, #27AE60); }
  .ball-plus { font-size: 1.5rem; color: #ccc; }
  .prize-info { margin-top: 16px; color: #666; }
  .prize-info strong { color: #E74C3C; font-size: 1.2rem; }

  .history-table { width: 100%; border-collapse: collapse; background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
  .history-table th { background: #1B4F72; color: white; padding: 14px 16px; font-size: 0.9rem; }
  .history-table td { padding: 14px 16px; text-align: center; border-bottom: 1px solid #eee; }
  .history-table tr:hover { background: #FAFBFC; }
  .mini-ball { width: 32px; height: 32px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; color: white; margin: 0 2px; }

  .frequency-section { margin-top: 32px; }
  .frequency-section h3 { font-size: 1.2rem; color: #1B4F72; margin-bottom: 20px; }
  .freq-grid { display: grid; grid-template-columns: repeat(9, 1fr); gap: 8px; }
  .freq-item { text-align: center; padding: 8px; border-radius: 8px; background: #F8F9FA; }
  .freq-item .number { font-weight: 700; font-size: 1.1rem; }
  .freq-item .count { font-size: 0.8rem; color: #888; }
  .freq-bar { height: 4px; border-radius: 2px; background: #eee; margin-top: 4px; overflow: hidden; }
  .freq-bar-fill { height: 100%; border-radius: 2px; background: #1B4F72; }

  @media (max-width: 768px) {
    .freq-grid { grid-template-columns: repeat(5, 1fr); }
    .history-table { font-size: 0.85rem; }
    .mini-ball { width: 26px; height: 26px; font-size: 0.7rem; }
  }
</style>

<div class="page-banner">
  <div class="container">
    <h1><i class="fas fa-search"></i> 당첨번호 조회</h1>
    <p>최신 로또 당첨번호와 통계를 확인하세요</p>
  </div>
</div>

<div class="lotto-container">
  <% if (latestDraw) { %>
    <div class="latest-draw">
      <h2>제 <%= latestDraw.draw_no %>회 당첨번호</h2>
      <p class="draw-info"><%= latestDraw.draw_date %> 추첨</p>
      <div class="lotto-display">
        <% const nums = [latestDraw.num1, latestDraw.num2, latestDraw.num3, latestDraw.num4, latestDraw.num5, latestDraw.num6]; %>
        <% nums.forEach(n => { %>
          <% let cls = n <= 10 ? 'ball-yellow' : n <= 20 ? 'ball-blue' : n <= 30 ? 'ball-red' : n <= 40 ? 'ball-gray' : 'ball-green'; %>
          <div class="lotto-ball <%= cls %>"><%= n %></div>
        <% }); %>
        <span class="ball-plus">+</span>
        <% let bCls = latestDraw.bonus <= 10 ? 'ball-yellow' : latestDraw.bonus <= 20 ? 'ball-blue' : latestDraw.bonus <= 30 ? 'ball-red' : latestDraw.bonus <= 40 ? 'ball-gray' : 'ball-green'; %>
        <div class="lotto-ball <%= bCls %>"><%= latestDraw.bonus %></div>
      </div>
      <p class="prize-info">1등 당첨금: <strong><%= (latestDraw.prize_1st / 100000000).toFixed(1) %>억원</strong> (<%= latestDraw.winners_1st %>명)</p>
    </div>
  <% } %>

  <!-- 등급별 당첨현황 분석 (201,955개 패턴 매칭 결과) -->
  <div style="background: white; border-radius: 16px; padding: 28px; box-shadow: 0 4px 16px rgba(0,0,0,0.08); margin-bottom: 32px;">
    <h2 style="text-align:center; color:#1B4F72; font-size: 1.6rem; font-weight: 800; margin-bottom: 8px;">등급별 당첨현황 분석</h2>
    <p style="text-align:center; color:#5D6D7E; font-size: 0.98rem; margin-bottom: 6px;">로또벅스88 앱은 확률 높은 번호 201,955개를 내장하고 있습니다.</p>
    <p style="text-align:center; color:#E74C3C; font-weight: 700; font-size: 1.02rem; margin-bottom: 24px;">이번주 당첨번호가 몇 개나 포함되어 있는지 확인하세요!</p>

    <div style="background: linear-gradient(135deg, #1565D8, #0D4A9E); color: white; padding: 20px 24px; border-radius: 12px; margin-bottom: 20px;">
      <div style="font-size: 1.15rem; font-weight: 800; margin-bottom: 4px;">제 1229회 당첨번호 분석</div>
      <div style="font-size: 0.92rem; opacity: 0.9; margin-bottom: 12px;">2026년 6월 20일 추첨</div>
      <div style="display: flex; gap: 8px; flex-wrap: wrap; align-items: center;">
        <span style="display:inline-flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:50%;background:#FBC02D;color:white;font-weight:800;font-size:0.9rem;">12</span>
        <span style="display:inline-flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:50%;background:#FBC02D;color:white;font-weight:800;font-size:0.9rem;">13</span>
        <span style="display:inline-flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:50%;background:#03A9F4;color:white;font-weight:800;font-size:0.9rem;">29</span>
        <span style="display:inline-flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:50%;background:#757575;color:white;font-weight:800;font-size:0.9rem;">34</span>
        <span style="display:inline-flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:50%;background:#757575;color:white;font-weight:800;font-size:0.9rem;">37</span>
        <span style="display:inline-flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:50%;background:#4CAF50;color:white;font-weight:800;font-size:0.9rem;">42</span>
        <span style="margin:0 4px;font-weight:700;">+</span>
        <span style="display:inline-flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:50%;background:#E74C3C;color:white;font-weight:800;font-size:0.9rem;">16</span>
      </div>
    </div>

    <table style="width:100%; border-collapse: collapse;">
      <thead>
        <tr style="background: #F5F7FA;">
          <th style="padding:14px 12px; color:#1B4F72; font-weight:700; text-align:center; border-bottom: 2px solid #E5E8EB;">등위</th>
          <th style="padding:14px 12px; color:#1B4F72; font-weight:700; text-align:center; border-bottom: 2px solid #E5E8EB;">내 적중 수</th>
          <th style="padding:14px 12px; color:#1B4F72; font-weight:700; text-align:center; border-bottom: 2px solid #E5E8EB;">당첨금</th>
          <th style="padding:14px 12px; color:#1B4F72; font-weight:700; text-align:center; border-bottom: 2px solid #E5E8EB;">당첨자 수</th>
        </tr>
      </thead>
      <tbody>
        <tr><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; font-weight:800; color:#E74C3C;">1등</td><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; font-weight:700; color:#2E7D32;">0개</td><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; font-weight:700; color:#E65100;">3,519,759,000원</td><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; color:#666;">8명</td></tr>
        <tr><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; font-weight:800; color:#1B4F72;">2등</td><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; font-weight:700; color:#2E7D32;">0개</td><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; font-weight:700; color:#E65100;">52,730,472원</td><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; color:#666;">89명</td></tr>
        <tr><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; font-weight:800; color:#1B4F72;">3등</td><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; font-weight:700; color:#2E7D32;">15개</td><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; font-weight:700; color:#E65100;">1,604,449원</td><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; color:#666;">2,925명</td></tr>
        <tr><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; font-weight:800; color:#1B4F72;">4등</td><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; font-weight:700; color:#2E7D32;">482개</td><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; font-weight:700; color:#E65100;">50,000원</td><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; color:#666;">152,290명</td></tr>
        <tr><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; font-weight:800; color:#1B4F72;">5등</td><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; font-weight:700; color:#2E7D32;">5,273개</td><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; font-weight:700; color:#E65100;">5,000원</td><td style="padding:14px 12px; text-align:center; border-bottom:1px solid #F0F2F5; color:#666;">2,583,834명</td></tr>
        <tr style="background:#FFF9E6;"><td style="padding:16px 12px; text-align:center; font-weight:800; color:#5D4017;">전체 합계</td><td style="padding:16px 12px; text-align:center; font-weight:800; color:#5D4017;">5,770개</td><td style="padding:16px 12px; text-align:center; font-weight:800; color:#5D4017;">—</td><td style="padding:16px 12px; text-align:center; font-weight:800; color:#5D4017;">2,737,146명</td></tr>
      </tbody>
    </table>
  </div>

  <h3 style="font-size:1.2rem; color:#1B4F72; margin-bottom:16px;"><i class="fas fa-history"></i> 최근 당첨번호</h3>
  <table class="history-table">
    <thead>
      <tr>
        <th>회차</th>
        <th>추첨일</th>
        <th>당첨번호</th>
        <th>보너스</th>
        <th>1등 당첨금</th>
      </tr>
    </thead>
    <tbody>
      <% results.forEach(r => { %>
        <tr>
          <td><strong><%= r.draw_no %></strong></td>
          <td><%= r.draw_date %></td>
          <td>
            <% [r.num1, r.num2, r.num3, r.num4, r.num5, r.num6].forEach(n => { %>
              <% let c = n <= 10 ? 'ball-yellow' : n <= 20 ? 'ball-blue' : n <= 30 ? 'ball-red' : n <= 40 ? 'ball-gray' : 'ball-green'; %>
              <span class="mini-ball <%= c %>"><%= n %></span>
            <% }); %>
          </td>
          <td>
            <% let bc = r.bonus <= 10 ? 'ball-yellow' : r.bonus <= 20 ? 'ball-blue' : r.bonus <= 30 ? 'ball-red' : r.bonus <= 40 ? 'ball-gray' : 'ball-green'; %>
            <span class="mini-ball <%= bc %>"><%= r.bonus %></span>
          </td>
          <td><%= (r.prize_1st / 100000000).toFixed(1) %>억</td>
        </tr>
      <% }); %>
    </tbody>
  </table>

</div>

<%- include('partials/footer') %>
