<%- include('partials/header') %>
<style>
  .page-banner { background: linear-gradient(135deg, #1B4F72, #2C3E50); color: white; padding: 48px 0; text-align: center; }
  .mypage-container { max-width: 800px; margin: 0 auto; padding: 32px 20px; }

  .profile-card { background: white; border-radius: 16px; padding: 32px; box-shadow: 0 4px 16px rgba(0,0,0,0.08); display: flex; gap: 24px; margin-bottom: 32px; }
  .profile-avatar { width: 100px; height: 100px; border-radius: 50%; background: linear-gradient(135deg, #1B4F72, #F39C12); display: flex; align-items: center; justify-content: center; font-size: 2.5rem; color: white; flex-shrink: 0; }
  .profile-info h2 { margin-bottom: 4px; }
  .profile-info .level { color: #F39C12; font-weight: 600; }
  .profile-stats { display: flex; gap: 24px; margin-top: 12px; }
  .stat-item { text-align: center; }
  .stat-item .value { font-size: 1.3rem; font-weight: 700; color: #1B4F72; }
  .stat-item .label { font-size: 0.8rem; color: #888; }

  .section-card { background: white; border-radius: 12px; padding: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); margin-bottom: 24px; }
  .section-card h3 { color: #1B4F72; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 2px solid #F39C12; }

  .form-group { margin-bottom: 16px; }
  .form-group label { display: block; font-weight: 500; margin-bottom: 6px; font-size: 0.9rem; }
  .form-group input { width: 100%; padding: 10px 14px; border: 1px solid #ddd; border-radius: 6px; font-size: 0.95rem; box-sizing: border-box; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .btn-save { padding: 10px 28px; background: #1B4F72; color: white; border: none; border-radius: 6px; font-weight: 600; cursor: pointer; }

  .post-list { list-style: none; padding: 0; }
  .post-list li { padding: 10px 0; border-bottom: 1px solid #f0f0f0; display: flex; justify-content: space-between; }
  .post-list li a { color: #333; text-decoration: none; }
  .post-list li a:hover { color: #1B4F72; }
  .post-list .meta { color: #999; font-size: 0.85rem; }

  @media (max-width: 768px) { .profile-card { flex-direction: column; text-align: center; } .form-row { grid-template-columns: 1fr; } }
</style>

<div class="page-banner"><div class="container"><h1><i class="fas fa-user-circle"></i> 마이페이지</h1></div></div>

<div class="mypage-container">
  <div class="profile-card">
    <div class="profile-avatar"><i class="fas fa-user"></i></div>
    <div class="profile-info">
      <h2><%= user.nickname %></h2>
      <p class="level">Lv.<%= user.level %> · <%= user.role === 'admin' ? '관리자' : '일반회원' %></p>
      <p style="color:#888; font-size:0.9rem;">@<%= user.username %> · 가입일: <%= user.created_at ? user.created_at.substring(0, 10) : '' %></p>
      <div class="profile-stats">
        <div class="stat-item"><div class="value"><%= user.point?.toLocaleString() || 0 %></div><div class="label">포인트</div></div>
        <div class="stat-item"><div class="value"><%= myPosts.length %></div><div class="label">게시글</div></div>
        <div class="stat-item"><div class="value"><%= myComments.length %></div><div class="label">댓글</div></div>
      </div>
    </div>
  </div>

  <div class="section-card">
    <h3><i class="fas fa-edit"></i> 프로필 수정</h3>
    <form id="profileForm">
      <div class="form-row">
        <div class="form-group"><label>닉네임</label><input type="text" id="pNickname" value="<%= user.nickname %>"></div>
        <div class="form-group"><label>이메일</label><input type="email" id="pEmail" value="<%= user.email %>"></div>
      </div>
      <div class="form-group"><label>휴대폰</label><input type="tel" id="pPhone" value="<%= user.phone || '' %>" placeholder="010-0000-0000"></div>
      <button type="submit" class="btn-save">저장하기</button>
    </form>
  </div>

  <div class="section-card">
    <h3><i class="fas fa-lock"></i> 비밀번호 변경</h3>
    <form id="pwForm">
      <div class="form-group"><label>현재 비밀번호</label><input type="password" id="currentPw"></div>
      <div class="form-row">
        <div class="form-group"><label>새 비밀번호</label><input type="password" id="newPw" placeholder="8자 이상"></div>
        <div class="form-group"><label>새 비밀번호 확인</label><input type="password" id="newPwConfirm"></div>
      </div>
      <button type="submit" class="btn-save">변경하기</button>
    </form>
  </div>

  <div class="section-card">
    <h3><i class="fas fa-file-alt"></i> 내가 쓴 글</h3>
    <ul class="post-list">
      <% if (myPosts.length > 0) { myPosts.forEach(p => { %>
        <li><a href="/board/<%= p.board_type %>/<%= p.id %>"><%= p.title %></a><span class="meta"><%= p.created_at ? p.created_at.substring(0, 10) : '' %></span></li>
      <% }); } else { %><li style="color:#999;">작성한 게시글이 없습니다.</li><% } %>
    </ul>
  </div>

  <div class="section-card">
    <h3><i class="fas fa-comment"></i> 내가 쓴 댓글</h3>
    <ul class="post-list">
      <% if (myComments.length > 0) { myComments.forEach(c => { %>
        <li><a href="/board/free/<%= c.post_id %>"><%= c.content.substring(0, 50) %><%= c.content.length > 50 ? '...' : '' %></a><span class="meta"><%= c.post_title %></span></li>
      <% }); } else { %><li style="color:#999;">작성한 댓글이 없습니다.</li><% } %>
    </ul>
  </div>
</div>

<script>
  document.getElementById('profileForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const res = await apiRequest('/auth/update-profile', {
      method: 'POST',
      body: {
        nickname: document.getElementById('pNickname').value,
        email: document.getElementById('pEmail').value,
        phone: document.getElementById('pPhone').value
      }
    });
    if (res.success) showToast('프로필이 수정되었습니다.', 'success');
  });

  document.getElementById('pwForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const res = await apiRequest('/auth/change-password', {
      method: 'POST',
      body: {
        currentPassword: document.getElementById('currentPw').value,
        newPassword: document.getElementById('newPw').value,
        newPasswordConfirm: document.getElementById('newPwConfirm').value
      }
    });
    if (res.success) {
      showToast('비밀번호가 변경되었습니다.', 'success');
      document.getElementById('pwForm').reset();
    }
  });
</script>

<%- include('partials/footer') %>
