  padding: 6px 18px;
  border: 1px solid #F39C12;
  border-radius: 30px;
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 0.5px;
  margin-bottom: 20px;
}
.qr-hero h1 {
  font-size: 2.6rem;
  font-weight: 900;
  line-height: 1.25;
  margin-bottom: 16px;
  letter-spacing: -0.5px;
}
.qr-hero h1 .highlight { color: #F5B041; }
.qr-hero .subtitle {
