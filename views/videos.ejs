<%- include('partials/header') %>
<style>
  .page-banner { background: linear-gradient(135deg, #1B4F72, #2C3E50); color: white; padding: 60px 0 50px; }
  .page-banner h1 { font-size: 2rem; margin-bottom: 10px; }
  .page-banner p { opacity: 0.85; font-size: 1.05rem; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }

  .videos-section { max-width: 1200px; margin: 0 auto; padding: 40px 20px; }
  .videos-section h2 { display:flex; align-items:center; gap:10px; font-size: 1.5rem; color: #1B4F72; margin-bottom: 6px; font-weight: 800; }
  .videos-section h2 i { color: #F39C12; }
  .videos-section .sub { color: #5D6D7E; margin-bottom: 24px; font-size: 0.95rem; }

  .single-video { max-width: 720px; margin: 0 auto; }
  .single-video .video-thumb { position: relative; padding-bottom: 56.25%; height: 0; background:#000; border-radius: 16px; overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,0.12); }
  .single-video .video-thumb iframe { position:absolute; top:0; left:0; width:100%; height:100%; border:0; }
  .single-video .body { padding: 18px 4px 0; text-align: center; }
  .single-video .body h3 { font-size: 1.2rem; color:#1B4F72; margin-bottom: 6px; }
  .single-video .body p { color: #7F8C8D; font-size: 0.95rem; }

  .video-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .video-card { background: white; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.07); border: 1px solid #ECEFF1; transition: all 0.3s; }
  .video-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.1); }
  .video-thumb { position: relative; padding-bottom: 56.25%; height: 0; background: #000; overflow:hidden; }
  .video-thumb iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0; }
  .video-body { padding: 16px 20px 20px; }
  .video-body h3 { font-size: 1rem; color: #1B4F72; margin-bottom: 8px; font-weight: 700; line-height: 1.4; }
  .video-body .desc { color: #7F8C8D; font-size: 0.85rem; line-height: 1.5; margin-bottom: 10px; }
  .video-body .meta { display: flex; justify-content: space-between; align-items: center; }
  .video-body .date { color: #95A5A6; font-size: 0.8rem; }
  .video-body .pin-badge { background: #F39C12; color: white; padding: 3px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 700; }

  .empty-state { text-align: center; padding: 40px 20px; color: #95A5A6; background: white; border-radius: 16px; border: 1px dashed #E5E8EB; }
  .empty-state i { font-size: 2rem; color: #BDC3C7; margin-bottom: 8px; }

  .divider { height: 1px; background: linear-gradient(to right, transparent, #E5E8EB, transparent); margin: 24px 0; }

  @media (max-width: 900px) { .video-grid { grid-template-columns: 1fr; } }
</style>

<div class="page-banner">
  <div class="container">
    <h1><i class="fas fa-video"></i> 영상</h1>
    <p>책, 조합기, 앱 소개 영상을 한 곳에서 확인하세요</p>
  </div>
</div>

<section class="videos-section">
  <h2><i class="fas fa-book"></i> 책 - 로또 1등 패턴의 정석</h2>
  <p class="sub">26년 연구의 정수를 영상으로 만나보세요</p>
  <% if (bookVideos && bookVideos.length > 0) { %>
    <div class="video-grid">
      <% bookVideos.forEach(function(book) { %>
        <div class="video-card">
          <div class="video-thumb"><iframe src="https://www.youtube.com/embed/<%= book.youtube_id %>" title="<%= book.title %>" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>
          <div class="video-body">
            <h3><%= book.title %></h3>
            <% if (book.description) { %><p class="desc"><%= book.description %></p><% } %>
            <div class="meta"><span class="date"><i class="far fa-calendar"></i> <%= new Date(book.created_at).toLocaleDateString('ko-KR') %></span><% if (book.is_pinned) { %><span class="pin-badge"><i class="fas fa-thumbtack"></i> 고정</span><% } %></div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } else { %><div class="empty-state"><i class="fas fa-video-slash"></i><p>책 영상 준비 중입니다.</p></div><% } %>
</section>

<div class="divider"></div>

<section class="videos-section">
  <h2><i class="fas fa-tv"></i> 조합기 - 로또분석조합기</h2>
  <p class="sub">조합기 사용법을 한 번에 알아보세요</p>
  <% if (machineVideos && machineVideos.length > 0) { %>
    <div class="single-video"><div class="video-thumb"><iframe src="https://www.youtube.com/embed/<%= machineVideos[0].youtube_id %>" title="<%= machineVideos[0].title %>" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div><div class="body"><h3><%= machineVideos[0].title %></h3><% if (machineVideos[0].description) { %><p><%= machineVideos[0].description %></p><% } %></div></div>
  <% } else { %><div class="empty-state"><i class="fas fa-video-slash"></i><p>조합기 소개 영상 준비 중입니다.</p></div><% } %>
</section>

<div class="divider"></div>

<section class="videos-section" style="padding-bottom:60px;">
  <h2><i class="fas fa-mobile-alt"></i> 앱 - 로또벅스88</h2>
  <p class="sub">앱 기능 사용법을 한 번에 알아보세요</p>
  <% if (appVideos && appVideos.length > 0) { %>
    <div class="single-video"><div class="video-thumb"><iframe src="https://www.youtube.com/embed/<%= appVideos[0].youtube_id %>" title="<%= appVideos[0].title %>" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div><div class="body"><h3><%= appVideos[0].title %></h3><% if (appVideos[0].description) { %><p><%= appVideos[0].description %></p><% } %></div></div>
  <% } else { %><div class="empty-state"><i class="fas fa-video-slash"></i><p>앱 소개 영상 준비 중입니다.</p></div><% } %>
</section>

<%- include('partials/footer') %>
